# =========================
# .gitignore for R2Drop
# =========================

# --- macOS ---
.DS_Store
.AppleDouble
.LSOverride
._*

# --- Rust ---
**/target/
**/*.rs.bk

# --- Swift / Xcode ---
**/.build/
**/.swiftpm/
**/DerivedData/
*.xcuserstate
xcuserdata/
*.xcworkspace/xcuserdata/
*.pbxuser
*.mode1v3
*.mode2v3
*.perspectivev3

# --- Internal docs ---
app/INSTRUMENTATION.md
docs/REQUIREMENTS.md

# --- Credentials & Secrets ---
app/credentials/
app/.env
.env
*.p12
*.cer
*.mobileprovision
*.provisionprofile

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- Misc ---
*.log
.r2drop-local/

# --- Claude Code local config ---
.claude/

# --- Replit project (separate repo with own git history) ---
replit/

# --- Local working documents (not for repo) ---
YOUTUBE.md
APPSTORE.md

# --- GIF working copies (committed via gitbook/assets/ instead) ---
art/screen-recording/*.gif

# --- Build artifacts ---
build/
app/build/
app/fastlane/build/
app/fastlane/report.xml

# --- Large binary files ---
*.psd

# --- Releases (binary artifacts, not source) ---
releases/
