# fastlane/Fastfile
# Lanes for R2Drop macOS app — TestFlight and Mac App Store distribution.
#
# Run from src/app/:
#   bundle exec fastlane testflight
#   bundle exec fastlane release_appstore
#
# Required env vars (set by CI or .env.local):
#   APP_STORE_CONNECT_API_KEY_ID      — App Store Connect API Key ID (349AL5RGAF)
#   APP_STORE_CONNECT_API_ISSUER_ID   — Issuer ID from App Store Connect
#   APP_STORE_CONNECT_API_KEY_CONTENT — Base64-encoded .p8 private key
#   APPLE_TEAM_ID             — Apple team ID (A89MU37ZLB)
#   BUILD_NUMBER              — Build number (e.g. GITHUB_RUN_NUMBER)
#   MARKETING_VERSION         — e.g. "0.1.0"
#   PROVISIONING_PROFILE_UUID — UUID of the installed App Store provisioning profile (app target)
#   PROVISIONING_PROFILE_FINDER_EXTENSION_UUID — UUID for FinderExtension profile (App Groups enabled)
#   PROVISIONING_PROFILE_QUICKACTION_EXTENSION_UUID — UUID for QuickActionExtension profile (App Groups enabled)
#
# NOTE: The FinderExtension (com.superhumancorp.r2drop.FinderExtension) needs its own
# App Store provisioning profile. `PROVISIONING_PROFILE_EXTENSION_UUID` is still
# accepted as a backward-compatible fallback for the FinderExtension profile only.

require "base64"
require "fileutils"
require "open3"
require "pathname"
require "shellwords"
require "tmpdir"

default_platform(:mac)

BUNDLE_ID         = "com.superhumancorp.r2drop"
BUNDLE_ID_FINDER  = "com.superhumancorp.r2drop.FinderExtension"
BUNDLE_ID_QUICK   = "com.superhumancorp.r2drop.QuickActionExtension"
TEAM_ID           = ENV.fetch("APPLE_TEAM_ID", "A89MU37ZLB")
PROJECT_ROOT      = File.expand_path("..", __dir__)
XCODEWORKSPACE    = File.join(PROJECT_ROOT, "R2Drop.xcworkspace")
PRODUCTION_SCHEME = ENV.fetch("XCODE_SCHEME", "R2Drop Production")
OUTPUT_DIR        = File.join(PROJECT_ROOT, "build", "fastlane")

platform :mac do
  def env_present?(key)
    !ENV.fetch(key, "").strip.empty?
  end

  # Local developers often don't have explicit provisioning UUIDs exported in .env.
  # In that case, use automatic signing and let Xcode resolve installed profiles.
  # CI / scripted releases should provide explicit UUIDs and use manual signing.
  def use_automatic_signing_for_local?
    return true if ENV.fetch("FORCE_AUTOMATIC_SIGNING", "") == "1"
    return false if ENV.fetch("CI", "").downcase == "true"
    return false if ENV.fetch("FORCE_MANUAL_SIGNING", "") == "1"

    profile_keys = [
      "PROVISIONING_PROFILE_UUID",
      "PROVISIONING_PROFILE_EXTENSION_UUID", # legacy FinderExtension fallback
      "PROVISIONING_PROFILE_FINDER_EXTENSION_UUID",
      "PROVISIONING_PROFILE_QUICKACTION_EXTENSION_UUID",
      "PROVISIONING_PROFILE_QUICK_ACTION_EXTENSION_UUID" # tolerated alias
    ]

    profile_keys.none? { |k| env_present?(k) }
  end

  def manual_provisioning_profiles!
    app_profile = ENV.fetch("PROVISIONING_PROFILE_UUID", "").strip
    finder_profile = ENV.fetch("PROVISIONING_PROFILE_FINDER_EXTENSION_UUID", "").strip
    finder_profile = ENV.fetch("PROVISIONING_PROFILE_EXTENSION_UUID", "").strip if finder_profile.empty?
    quick_profile = ENV.fetch("PROVISIONING_PROFILE_QUICKACTION_EXTENSION_UUID", "").strip
    quick_profile = ENV.fetch("PROVISIONING_PROFILE_QUICK_ACTION_EXTENSION_UUID", "").strip if quick_profile.empty?

    missing = []
    missing << "PROVISIONING_PROFILE_UUID (#{BUNDLE_ID})" if app_profile.empty?
    missing << "PROVISIONING_PROFILE_FINDER_EXTENSION_UUID or PROVISIONING_PROFILE_EXTENSION_UUID (#{BUNDLE_ID_FINDER})" if finder_profile.empty?
    missing << "PROVISIONING_PROFILE_QUICKACTION_EXTENSION_UUID (#{BUNDLE_ID_QUICK})" if quick_profile.empty?

    unless missing.empty?
      UI.user_error!(
        "Missing provisioning profile UUID env var(s) for manual signing:\n" \
        "  - #{missing.join("\n  - ")}\n" \
        "All three profiles must exist and include the App Groups capability."
      )
    end

    {
      BUNDLE_ID => app_profile,
      BUNDLE_ID_FINDER => finder_profile,
      BUNDLE_ID_QUICK => quick_profile
    }
  end

  # Fastlane's macOS packaging step may need an explicit installer certificate name
  # to produce a .pkg. We accept an env override and otherwise try to auto-detect a
  # suitable identity from the local keychain.
  def resolve_installer_cert_name
    env_name = ENV.fetch("INSTALLER_CERT_NAME", "").strip
    env_name = ENV.fetch("MAC_INSTALLER_CERT_NAME", "").strip if env_name.empty?
    return env_name unless env_name.empty?

    identities_output = `security find-identity -v 2>/dev/null`
    names = identities_output.lines.filter_map do |line|
      match = line.match(/"([^"]+)"/)
      match && match[1]
    end

    team_suffix = "(#{TEAM_ID})"
    candidates = [
      "3rd Party Mac Developer Installer: ",
      "Mac Installer Distribution: "
    ]

    candidates.each do |prefix|
      name = names.find { |n| n.start_with?(prefix) && n.include?(team_suffix) }
      return name if name
    end

    nil
  end

  def ensure_installer_cert_available!
    installer_cert_name = resolve_installer_cert_name
    return installer_cert_name unless installer_cert_name.nil? || installer_cert_name.empty?

    UI.user_error!(
      "No Mac App Store installer certificate was found in your keychain.\n" \
      "TestFlight / App Store uploads require a package-signing certificate such as:\n" \
      "  - 3rd Party Mac Developer Installer: <Name> (#{TEAM_ID})\n" \
      "  - Mac Installer Distribution: <Name> (#{TEAM_ID})\n" \
      "Install the certificate in Keychain Access, or set INSTALLER_CERT_NAME / MAC_INSTALLER_CERT_NAME."
    )
  end

  def asc_api_key_env_hash
    key_id = ENV.fetch("APP_STORE_CONNECT_API_KEY_ID", "").strip
    issuer_id = ENV.fetch("APP_STORE_CONNECT_API_ISSUER_ID", "").strip
    key_content = ENV.fetch("APP_STORE_CONNECT_API_KEY_CONTENT", "").strip
    key_path = ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH", "").strip

    present = [
      ["APP_STORE_CONNECT_API_KEY_ID", key_id],
      ["APP_STORE_CONNECT_API_ISSUER_ID", issuer_id],
      ["APP_STORE_CONNECT_API_KEY_CONTENT", key_content],
      ["APP_STORE_CONNECT_API_KEY_PATH", key_path]
    ].select { |_k, v| !v.empty? }.map(&:first)

    has_path = !key_path.empty?
    has_content = !key_content.empty?

    if present.any?
      if key_id.empty? || issuer_id.empty? || (!has_path && !has_content) || (has_path && has_content)
        UI.user_error!(
          "Invalid App Store Connect API key env configuration.\n" \
          "Set exactly one of APP_STORE_CONNECT_API_KEY_CONTENT or APP_STORE_CONNECT_API_KEY_PATH,\n" \
          "and also set APP_STORE_CONNECT_API_KEY_ID + APP_STORE_CONNECT_API_ISSUER_ID."
        )
      end
    else
      return nil
    end

    {
      key_id: key_id,
      issuer_id: issuer_id,
      key_content: key_content,
      key_path: key_path
    }
  end

  def prepare_asc_auth_context
    cfg = asc_api_key_env_hash
    return { fastlane_api_key: nil, xcode_auth_flags: [], cleanup_paths: [] } if cfg.nil?

    cleanup_paths = []
    key_file_path = cfg[:key_path]

    if key_file_path.empty?
      decoded = begin
        Base64.strict_decode64(cfg[:key_content])
      rescue StandardError
        cfg[:key_content]
      end

      dir = Dir.mktmpdir("r2drop-asc-key")
      cleanup_paths << dir
      key_file_path = File.join(dir, "AuthKey_#{cfg[:key_id]}.p8")
      File.write(key_file_path, decoded)
      File.chmod(0o600, key_file_path)
    end

    api_key = app_store_connect_api_key(
      key_id: cfg[:key_id],
      issuer_id: cfg[:issuer_id],
      key_filepath: key_file_path
    )

    xcode_auth_flags = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath", key_file_path,
      "-authenticationKeyID", cfg[:key_id],
      "-authenticationKeyIssuerID", cfg[:issuer_id]
    ]

    {
      fastlane_api_key: api_key,
      xcode_auth_flags: xcode_auth_flags,
      cleanup_paths: cleanup_paths
    }
  end

  def cleanup_asc_auth_context!(ctx)
    return if ctx.nil?
    Array(ctx[:cleanup_paths]).each do |p|
      next if p.to_s.empty?
      FileUtils.rm_rf(p) if File.exist?(p)
    rescue StandardError
      nil
    end
  end

  # `pilot` / `deliver` can auto-consume APP_STORE_CONNECT_API_KEY_* env vars, but
  # their `api_key_path` option expects a JSON descriptor file, not a raw `.p8`.
  # We use APP_STORE_CONNECT_API_KEY_PATH for the raw `.p8` path in local workflows,
  # so pass the explicit `api_key` object and temporarily clear conflicting env vars.
  def with_cleared_asc_env_for_upload
    keys = %w[
      APP_STORE_CONNECT_API_KEY_ID
      APP_STORE_CONNECT_API_ISSUER_ID
      APP_STORE_CONNECT_API_KEY_PATH
      APP_STORE_CONNECT_API_KEY_CONTENT
    ]
    snapshot = {}
    keys.each do |k|
      snapshot[k] = ENV.key?(k) ? ENV[k] : :__absent__
      ENV.delete(k)
    end
    yield
  ensure
    snapshot&.each do |k, v|
      if v == :__absent__
        ENV.delete(k)
      else
        ENV[k] = v
      end
    end
  end

  def with_temp_env(overrides = {})
    snapshot = {}
    overrides.each do |k, v|
      key = k.to_s
      snapshot[key] = ENV.key?(key) ? ENV[key] : :__absent__
      if v.nil?
        ENV.delete(key)
      else
        ENV[key] = v.to_s
      end
    end
    yield
  ensure
    snapshot&.each do |k, v|
      if v == :__absent__
        ENV.delete(k)
      else
        ENV[k] = v
      end
    end
  end

  def write_export_options_plist(path:, signing_style:, provisioning_profiles: nil)
    method = "app-store-connect"
    lines = []
    lines << %(<?xml version="1.0" encoding="UTF-8"?>)
    lines << %(<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">)
    lines << %(<plist version="1.0">)
    lines << %(<dict>)
    lines << %(  <key>method</key>)
    lines << %(  <string>#{method}</string>)
    lines << %(  <key>teamID</key>)
    lines << %(  <string>#{TEAM_ID}</string>)
    lines << %(  <key>signingStyle</key>)
    lines << %(  <string>#{signing_style}</string>)
    if signing_style == "manual" && provisioning_profiles && !provisioning_profiles.empty?
      lines << %(  <key>provisioningProfiles</key>)
      lines << %(  <dict>)
      provisioning_profiles.each do |bundle_id, uuid|
        lines << %(    <key>#{bundle_id}</key>)
        lines << %(    <string>#{uuid}</string>)
      end
      lines << %(  </dict>)
    end
    lines << %(</dict>)
    lines << %(</plist>)
    File.write(path, lines.join("\n"))
  end

  def run_command_capture!(args)
    UI.command(args.map { |a| a.to_s }.join(" "))
    output, status = Open3.capture2e(*args)
    UI.message(output) unless output.to_s.empty?
    [output, status]
  end

  def resolve_developer_id_application_cert_name
    env_name = ENV.fetch("DMG_SIGN_IDENTITY", "").strip
    env_name = ENV.fetch("DEVELOPER_ID_APPLICATION_CERT_NAME", "").strip if env_name.empty?
    return env_name unless env_name.empty?

    identities_output = `security find-identity -v -p codesigning 2>/dev/null`
    names = identities_output.lines.filter_map do |line|
      match = line.match(/"([^"]+)"/)
      match && match[1]
    end.uniq

    preferred = "Developer ID Application: Paul Pierre (#{TEAM_ID})"
    exact = names.find { |n| n == preferred }
    return exact if exact

    names.find { |n| n.start_with?("Developer ID Application: ") && n.include?("(#{TEAM_ID})") }
  end

  def local_dmg_notarization_enabled?
    flag = ENV.fetch("DMG_NOTARIZE", "").strip.downcase
    return true if %w[1 true yes y].include?(flag)
    return false if %w[0 false no n].include?(flag)

    # Default: notarize when credentials exist.
    env_present?("APPLE_ID") &&
      env_present?("APPLE_APP_PASSWORD") &&
      env_present?("APPLE_TEAM_ID")
  end

  def build_local_arch_app!(arch:, marketing_version:, build_number:)
    derived_data_dir = File.join(PROJECT_ROOT, "build", "dmg-#{arch}")
    FileUtils.mkdir_p(derived_data_dir)

    args = [
      "xcodebuild",
      "-workspace", XCODEWORKSPACE,
      "-scheme", PRODUCTION_SCHEME,
      "-configuration", "Release",
      "-derivedDataPath", derived_data_dir,
      "-destination", "generic/platform=macOS",
      "ARCHS=#{arch}",
      "ONLY_ACTIVE_ARCH=YES",
      "MARKETING_VERSION=#{marketing_version}",
      "CURRENT_PROJECT_VERSION=#{build_number}",
      "clean",
      "build"
    ]

    _output, status = run_command_capture!(args)
    unless status.success?
      UI.user_error!("xcodebuild failed while building #{arch} app bundle for local DMG release.")
    end

    app_path = File.join(derived_data_dir, "Build", "Products", "Release", "R2Drop.app")
    UI.user_error!("Expected app bundle not found at #{app_path}") unless File.directory?(app_path)
    app_path
  end

  def package_local_dmg!(app_path:, sign_identity:, arch_slug:)
    script_path = File.join(PROJECT_ROOT, "scripts", "generate-dmg.sh")
    args = [script_path, "--app", app_path]
    args += ["--sign", sign_identity] unless sign_identity.to_s.empty?

    _output, status = run_command_capture!(args)
    unless status.success?
      UI.user_error!("DMG packaging failed for app bundle at #{app_path}")
    end

    generated = Dir[File.join(PROJECT_ROOT, "build", "R2Drop-*.dmg")].max_by { |p| File.mtime(p) }
    UI.user_error!("No DMG found in #{File.join(PROJECT_ROOT, "build")} after packaging.") if generated.nil?

    version = File.basename(generated).sub(/\AR2Drop-/, "").sub(/\.dmg\z/, "")
    final_dmg = File.join(PROJECT_ROOT, "build", "R2Drop-#{version}-#{arch_slug}.dmg")
    FileUtils.rm_f(final_dmg)
    FileUtils.mv(generated, final_dmg)
    final_dmg
  end

  def notarize_and_staple_dmg!(dmg_path:, apple_id:, app_password:, team_id:)
    _submit_output, submit_status = run_command_capture!([
      "xcrun", "notarytool", "submit", dmg_path,
      "--apple-id", apple_id,
      "--password", app_password,
      "--team-id", team_id,
      "--wait"
    ])
    unless submit_status.success?
      UI.user_error!("Notarization failed for #{dmg_path}")
    end

    _staple_output, staple_status = run_command_capture!(["xcrun", "stapler", "staple", dmg_path])
    unless staple_status.success?
      UI.user_error!("Stapling failed for #{dmg_path}")
    end
  end

  def manual_export_pkg_from_archive!(archive_path:, signing_style:, provisioning_profiles:, auth_ctx:)
    export_dir = File.join(OUTPUT_DIR, "export")
    FileUtils.rm_rf(export_dir)
    FileUtils.mkdir_p(export_dir)

    export_plist = File.join(Dir.tmpdir, "r2drop-export-options-#{Time.now.to_i}-#{$$}.plist")
    write_export_options_plist(
      path: export_plist,
      signing_style: signing_style,
      provisioning_profiles: provisioning_profiles
    )

    args = [
      "xcodebuild",
      "-exportArchive",
      "-archivePath", archive_path,
      "-exportPath", export_dir,
      "-exportOptionsPlist", export_plist
    ]

    auth_flags = Array(auth_ctx && auth_ctx[:xcode_auth_flags])
    args.concat(auth_flags) unless auth_flags.empty?

    output, status = run_command_capture!(args)
    FileUtils.rm_f(export_plist)

    unless status.success?
      hints = []
      if output.include?("session has expired") || output.include?("Unable to log in with account")
        hints << "Your Xcode Apple Developer session is expired. Open Xcode > Settings > Accounts and sign in again, or set APP_STORE_CONNECT_API_KEY_* env vars so xcodebuild can authenticate non-interactively."
      end
      if output =~ /No signing certificate .*Installer/i || output.include?("No Mac Installer Distribution")
        hints << "Install a Mac App Store installer certificate (e.g. 'Mac Installer Distribution' or '3rd Party Mac Developer Installer') in Keychain Access for team #{TEAM_ID}."
      end
      if output.include?("requires a provisioning profile with the App Groups feature")
        hints << "Use App Store provisioning profiles for the app and both extensions that include the App Groups capability (or allow automatic signing with a valid developer session/API key)."
      end

      hint_text = hints.empty? ? "" : "\n\n" + hints.map { |h| "- #{h}" }.join("\n")
      UI.user_error!("xcodebuild -exportArchive failed while packaging the TestFlight/App Store .pkg.#{hint_text}")
    end

    pkg_path = Dir[File.join(export_dir, "*.pkg")].max_by { |p| File.mtime(p) }
    unless pkg_path && File.exist?(pkg_path)
      UI.user_error!("xcodebuild export succeeded but no .pkg was produced in #{export_dir}.")
    end

    File.expand_path(pkg_path)
  end

  # ---------------------------------------------------------------------------
  # Shared build helper — archives and exports a signed .pkg for App Store
  # ---------------------------------------------------------------------------
  def build_for_appstore(build_number, marketing_version)
    auth_ctx = prepare_asc_auth_context
    automatic_signing = use_automatic_signing_for_local?
    provisioning_profiles_for_manual = nil
    xcargs_list = [
      "CURRENT_PROJECT_VERSION=#{build_number}",
      "MARKETING_VERSION=#{marketing_version}",
      "DEVELOPMENT_TEAM=#{TEAM_ID}"
    ]

    export_options = {
      method: "app-store",
      teamID: TEAM_ID
    }

    if automatic_signing
      UI.important("No provisioning profile UUIDs supplied; using automatic signing for local archive/export.")
      export_options[:signingStyle] = "automatic"
      xcargs_list << "CODE_SIGN_STYLE=Automatic"
      if auth_ctx[:xcode_auth_flags].empty?
        UI.important("No App Store Connect API key env vars found; automatic signing will rely on your active Xcode Apple Developer session.")
      end
      # Let Xcode choose the correct identity for all targets (app, extensions, SPM products)
      # under automatic signing. Forcing Apple Distribution here conflicts with development
      # auto-signing and breaks archive.
    else
      export_options[:signingStyle] = "manual"
      provisioning_profiles_for_manual = manual_provisioning_profiles!
      export_options[:provisioningProfiles] = provisioning_profiles_for_manual
      xcargs_list << "CODE_SIGN_STYLE=Manual"
      xcargs_list << "CODE_SIGN_IDENTITY=Apple Distribution"
    end

    installer_cert_name = ensure_installer_cert_available!

    unless auth_ctx[:xcode_auth_flags].empty?
      xcargs_list.concat(auth_ctx[:xcode_auth_flags])
    end

    gym_options = {
      workspace: XCODEWORKSPACE,
      scheme: PRODUCTION_SCHEME,
      configuration: "Release",
      export_method: "app-store",
      clean: true,
      output_directory: OUTPUT_DIR,
      output_name: "R2Drop",
      export_options: export_options,
      skip_package_pkg: false,
      # Shell-escape build settings so values with spaces (e.g. signing identities)
      # do not get split and misparsed as xcodebuild actions.
      xcargs: Shellwords.join(xcargs_list)
    }

    UI.message("Using installer certificate for pkg packaging: #{installer_cert_name}")
    gym_options[:installer_cert_name] = installer_cert_name
    unless auth_ctx[:xcode_auth_flags].empty?
      gym_options[:export_xcargs] = Shellwords.join(auth_ctx[:xcode_auth_flags])
    end

    gym_artifact = gym(**gym_options)

    pkg_output = Actions.lane_context[SharedValues::PKG_OUTPUT_PATH]
    pkg_output = gym_artifact if pkg_output.to_s.empty? && gym_artifact.to_s.end_with?(".pkg")
    pkg_output = File.expand_path(pkg_output) unless pkg_output.to_s.empty? || Pathname.new(pkg_output).absolute?

    unless pkg_output && File.exist?(pkg_output)
      archive_path = Actions.lane_context[SharedValues::XCODEBUILD_ARCHIVE]
      if archive_path.to_s.empty? || !File.exist?(archive_path)
        UI.user_error!(
          "gym archive succeeded but no .pkg was produced, and the archive path was unavailable for manual export fallback."
        )
      end

      UI.important("gym did not produce a .pkg; attempting manual xcodebuild -exportArchive packaging fallback…")
      pkg_output = manual_export_pkg_from_archive!(
        archive_path: archive_path,
        signing_style: automatic_signing ? "automatic" : "manual",
        provisioning_profiles: provisioning_profiles_for_manual || export_options[:provisioningProfiles],
        auth_ctx: auth_ctx
      )
    end

    [pkg_output, auth_ctx[:fastlane_api_key]]
  rescue StandardError
    raise
  ensure
    cleanup_asc_auth_context!(auth_ctx)
  end

  # ---------------------------------------------------------------------------
  # build_local_dmg — build signed DMGs locally for arm64 + x86_64
  # ---------------------------------------------------------------------------
  desc "Build local DMG release artifacts (arm64 + x86_64), optionally notarized"
  lane :build_local_dmg do
    marketing_version = ENV.fetch("MARKETING_VERSION", "0.1.0")
    build_number = ENV.fetch("BUILD_NUMBER", Time.now.strftime("%Y%m%d%H%M"))
    sign_enabled = !%w[0 false no n].include?(ENV.fetch("DMG_SIGN", "1").strip.downcase)
    notarize_enabled = local_dmg_notarization_enabled?

    sign_identity = ""
    if sign_enabled
      sign_identity = resolve_developer_id_application_cert_name.to_s
      if sign_identity.empty?
        UI.user_error!(
          "Unable to resolve a Developer ID Application signing identity.\n" \
          "Set DMG_SIGN_IDENTITY explicitly, for example:\n" \
          "  DMG_SIGN_IDENTITY='Developer ID Application: Paul Pierre (#{TEAM_ID})'"
        )
      end
    end

    if notarize_enabled
      unless env_present?("APPLE_ID") && env_present?("APPLE_APP_PASSWORD") && env_present?("APPLE_TEAM_ID")
        UI.user_error!(
          "DMG notarization requested, but APPLE_ID / APPLE_APP_PASSWORD / APPLE_TEAM_ID are missing."
        )
      end
    end

    UI.message "Building local DMG artifacts v#{marketing_version} (#{build_number})…"
    UI.message "Signing enabled: #{sign_enabled ? "yes (#{sign_identity})" : "no"}"
    UI.message "Notarization enabled: #{notarize_enabled ? "yes" : "no"}"

    run_command_capture!([File.join(PROJECT_ROOT, "scripts", "build-rust.sh"), "--release"])

    outputs = []
    [
      { arch: "arm64", arch_slug: "aarch64" },
      { arch: "x86_64", arch_slug: "x86_64" }
    ].each do |cfg|
      app_path = build_local_arch_app!(
        arch: cfg[:arch],
        marketing_version: marketing_version,
        build_number: build_number
      )

      dmg_path = package_local_dmg!(
        app_path: app_path,
        sign_identity: sign_enabled ? sign_identity : "",
        arch_slug: cfg[:arch_slug]
      )

      if notarize_enabled
        notarize_and_staple_dmg!(
          dmg_path: dmg_path,
          apple_id: ENV.fetch("APPLE_ID"),
          app_password: ENV.fetch("APPLE_APP_PASSWORD"),
          team_id: ENV.fetch("APPLE_TEAM_ID")
        )
      end

      outputs << dmg_path
    end

    UI.success("Local DMG build complete:")
    outputs.each { |path| UI.success("  - #{path}") }
  end

  desc "Alias for build_local_dmg"
  lane :dmg_release do
    build_local_dmg
  end

  # ---------------------------------------------------------------------------
  # testflight — build and upload to TestFlight
  # ---------------------------------------------------------------------------
  desc "Build R2Drop and upload to TestFlight"
  lane :upload_testflight do
    build_number     = ENV.fetch("BUILD_NUMBER", Time.now.strftime("%Y%m%d%H%M"))
    marketing_version = ENV.fetch("MARKETING_VERSION", "0.1.0")

    UI.message "Building #{BUNDLE_ID} v#{marketing_version} (#{build_number}) for TestFlight…"

    pkg_path, api_key = build_for_appstore(build_number, marketing_version)
    pkg_path = File.expand_path(pkg_path)
    UI.user_error!("Expected TestFlight pkg not found at #{pkg_path}") unless File.exist?(pkg_path)
    UI.message("Uploading pkg to TestFlight: #{pkg_path}")

    options = {
      app_identifier: BUNDLE_ID,
      pkg: pkg_path,
      skip_waiting_for_build_processing: true
    }
    options[:api_key] = api_key unless api_key.nil?
    with_cleared_asc_env_for_upload do
      with_temp_env("PILOT_PKG" => pkg_path) do
        upload_to_testflight(**options)
      end
    end

    UI.success "Uploaded v#{marketing_version} (#{build_number}) to TestFlight."
  end

  # Backward-compatible alias used by CI (`bundle exec fastlane testflight`)
  desc "Alias for upload_testflight"
  lane :testflight do
    upload_testflight
  end

  # ---------------------------------------------------------------------------
  # release_appstore — build and submit to Mac App Store review
  # ---------------------------------------------------------------------------
  desc "Build R2Drop and submit to Mac App Store"
  lane :release_appstore do
    build_number      = ENV.fetch("BUILD_NUMBER", Time.now.strftime("%Y%m%d%H%M"))
    marketing_version = ENV.fetch("MARKETING_VERSION", "0.1.0")

    UI.message "Building #{BUNDLE_ID} v#{marketing_version} (#{build_number}) for App Store…"

    pkg_path, api_key = build_for_appstore(build_number, marketing_version)
    pkg_path = File.expand_path(pkg_path)
    UI.user_error!("Expected App Store pkg not found at #{pkg_path}") unless File.exist?(pkg_path)
    UI.message("Uploading pkg to App Store: #{pkg_path}")

    options = {
      app_identifier: BUNDLE_ID,
      pkg: pkg_path,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      skip_screenshots: true,
      skip_metadata: true
    }
    options[:api_key] = api_key unless api_key.nil?
    with_cleared_asc_env_for_upload do
      with_temp_env("DELIVER_PKG" => pkg_path) do
        upload_to_app_store(**options)
      end
    end

    UI.success "Submitted v#{marketing_version} (#{build_number}) to App Store review."
  end

  # Backward-compatible alias if CI/scripts call `fastlane appstore`
  desc "Alias for release_appstore"
  lane :appstore do
    release_appstore
  end
end
